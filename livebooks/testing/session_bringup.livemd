## Helpers

```elixir
alias EtherCAT.Domain.API, as: DomainAPI

await_running! = fn timeout_ms \\ 15_000 ->
  case EtherCAT.await_running(timeout_ms) do
    :ok -> EtherCAT.state()
    {:error, reason} -> raise "session did not reach a usable state: #{inspect(reason)}"
  end
end

activate_if_needed! = fn timeout_ms \\ 15_000 ->
  case EtherCAT.state() do
    :operational ->
      :ok

    :preop_ready ->
      :ok = EtherCAT.activate()
      EtherCAT.await_operational(timeout_ms)

    other ->
      {:error, {:unexpected_state, other}}
  end
end
```

## Wait For A Usable Session

```elixir
%{
  await_running: EtherCAT.await_running(15_000),
  state: EtherCAT.state(),
  last_failure: EtherCAT.last_failure(),
  dc_status: EtherCAT.dc_status()
}
```

## Activate If Needed

```elixir
case EtherCAT.state() do
  :operational ->
    :ok

  :preop_ready ->
    :ok = EtherCAT.activate()
    :ok = EtherCAT.await_operational(15_000)

  other ->
    {:error, {:unexpected_state, other}}
end
```

## Runtime Overview

```elixir
tabs =
  [
    {"Master", KinoEtherCAT.master()},
    {"Task Manager", KinoEtherCAT.diagnostics()},
    {"Bus", KinoEtherCAT.bus()},
    {"DC", KinoEtherCAT.dc()}
  ] ++
    Enum.map(EtherCAT.slaves(), fn %{name: name} ->
      {"Slave #{name}", KinoEtherCAT.slave(name)}
    end)

Kino.Layout.tabs(tabs)
```

## Optional Domain Pause / Resume

```elixir
domain_id = :main

:ok = DomainAPI.stop_cycling(domain_id)
EtherCAT.domain_info(domain_id)
```

```elixir
domain_id = :main

:ok = DomainAPI.start_cycling(domain_id)
%{
  state: EtherCAT.state(),
  domain: EtherCAT.domain_info(domain_id)
}
```

