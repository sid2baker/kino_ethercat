```elixir

```

## Helpers

```elixir
await_input = fn slave, signal, expected, timeout_ms ->
  deadline = System.monotonic_time(:millisecond) + timeout_ms

  Stream.repeatedly(fn -> EtherCAT.read_input(slave, signal) end)
  |> Enum.reduce_while(nil, fn value, _acc ->
    cond do
      value == expected ->
        {:halt, :ok}

      System.monotonic_time(:millisecond) >= deadline ->
        {:halt, {:error, {:timeout, slave, signal, expected, value}}}

      true ->
        Process.sleep(20)
        {:cont, nil}
    end
  end)
end
```

## Configuration

```elixir
pairs = [
  ch1: :ch1,
  ch2: :ch2,
  ch3: :ch3,
  ch4: :ch4
]

settle_ms = 250
```

## Run

```elixir
results =
  for {output_signal, input_signal} <- pairs do
    :ok = EtherCAT.write_output(:outputs, output_signal, 1)
    high = await_input.(:inputs, input_signal, 1, settle_ms)

    :ok = EtherCAT.write_output(:outputs, output_signal, 0)
    low = await_input.(:inputs, input_signal, 0, settle_ms)

    %{
      output: output_signal,
      input: input_signal,
      high: high,
      low: low
    }
  end

failures =
  Enum.filter(results, fn row ->
    row.high != :ok or row.low != :ok
  end)

%{
  status: if(failures == [], do: :ok, else: :error),
  results: results,
  failures: failures
}
```

## Tidy Up

```elixir
Enum.each(pairs, fn {output_signal, _input_signal} ->
  :ok = EtherCAT.write_output(:outputs, output_signal, 0)
end)

:ok
```
